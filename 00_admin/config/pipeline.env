#!/usr/bin/env bash
# Shared configuration for RNA-seq pipeline (D. melanogaster, Ensembl release 113)

PROJECT_ROOT="${PROJECT_ROOT:-${SLURM_SUBMIT_DIR:-$(pwd)}}"
SAMPLES_TSV="${SAMPLES_TSV:-${PROJECT_ROOT}/00_admin/metadata/samples.tsv}"

SPECIES="${SPECIES:-drosophila_melanogaster}"
ASSEMBLY="${ASSEMBLY:-BDGP6.46}"
ENSEMBL_RELEASE="${ENSEMBL_RELEASE:-113}"

REFERENCE_DIR="${REFERENCE_DIR:-${PROJECT_ROOT}/02_work/04_ref/reference}"
STAR_INDEX_DIR="${STAR_INDEX_DIR:-${PROJECT_ROOT}/02_work/04_ref/star_index}"

FASTA_BASENAME="${FASTA_BASENAME:-Drosophila_melanogaster.${ASSEMBLY}.dna.toplevel.fa.gz}"
GTF_BASENAME="${GTF_BASENAME:-Drosophila_melanogaster.${ASSEMBLY}.${ENSEMBL_RELEASE}.gtf.gz}"

FASTA_URL="${FASTA_URL:-https://ftp.ensembl.org/pub/release-${ENSEMBL_RELEASE}/fasta/${SPECIES}/dna/${FASTA_BASENAME}}"
GTF_URL="${GTF_URL:-https://ftp.ensembl.org/pub/release-${ENSEMBL_RELEASE}/gtf/${SPECIES}/${GTF_BASENAME}}"

FASTA_GZ="${FASTA_GZ:-${REFERENCE_DIR}/${FASTA_BASENAME}}"
GTF_GZ="${GTF_GZ:-${REFERENCE_DIR}/${GTF_BASENAME}}"
FASTA="${FASTA:-${REFERENCE_DIR}/${FASTA_BASENAME%.gz}}"
GTF="${GTF:-${REFERENCE_DIR}/${GTF_BASENAME%.gz}}"

TRIM_DIR="${TRIM_DIR:-${PROJECT_ROOT}/02_work/02_trim/fastp}"
ALIGN_DIR="${ALIGN_DIR:-${PROJECT_ROOT}/02_work/05_align/star}"
ALIGN_QC_DIR="${ALIGN_QC_DIR:-${PROJECT_ROOT}/02_work/05_align/multiqc}"

COUNTS_DIR="${COUNTS_DIR:-${PROJECT_ROOT}/02_work/06_counts/final}"

SLURM_LOG_DIR="${SLURM_LOG_DIR:-${PROJECT_ROOT}/04_logs/slurm}"
TMP_ROOT="${TMP_ROOT:-${PROJECT_ROOT}/90_scratch/tmp}"
MULTIQC_VENV="${MULTIQC_VENV:-${PROJECT_ROOT}/00_admin/env/multiqc_venv}"

# Compute resources (align with sbatch directives)
STAR_INDEX_THREADS="${STAR_INDEX_THREADS:-12}"
STAR_ALIGN_THREADS="${STAR_ALIGN_THREADS:-8}"
STAR_ALIGN_SORT_RAM="${STAR_ALIGN_SORT_RAM:-8000000000}"
FEATURECOUNTS_THREADS="${FEATURECOUNTS_THREADS:-8}"
FEATURECOUNTS_STRAND="${FEATURECOUNTS_STRAND:-0}"

# Cluster modules
STACK_MODULE="${STACK_MODULE:-stack/2024-06}"
GCC_MODULE="${GCC_MODULE:-gcc/12.2.0}"
FASTQC_MODULE="${FASTQC_MODULE:-fastqc}"
PYTHON_MODULE="${PYTHON_MODULE:-python/3.11.6}"
STAR_MODULE="${STAR_MODULE:-star/2.7.10b}"
SUBREAD_MODULE="${SUBREAD_MODULE:-subread/2.0.6}"
SAMTOOLS_MODULE="${SAMTOOLS_MODULE:-samtools/1.17}"
JAVA_HOME="${JAVA_HOME:-/cluster/software/stacks/2025-06/linux-ubuntu22.04-x86_64_v3/oneapi-2023.2.0/openjdk-17.0.11_9-3ttcgzsh7kizb32kd5g6cfeeidea4ujf}"

# Qualimap (local install) & global MultiQC
QUALIMAP_HOME="${QUALIMAP_HOME:-${PROJECT_ROOT}/00_admin/env/qualimap}"
QUALIMAP_DIR="${QUALIMAP_DIR:-${PROJECT_ROOT}/02_work/05_align/qualimap}"
QUALIMAP_MEM="${QUALIMAP_MEM:-10G}"
MULTIQC_ALL_DIR="${MULTIQC_ALL_DIR:-${PROJECT_ROOT}/02_work/multiqc_all}"

# --- 1*_ pipeline ---
QC11_DIR="${QC11_DIR:-${PROJECT_ROOT}/02_work/11_qc_raw}"
SORTMERNA_DIR="${SORTMERNA_DIR:-${PROJECT_ROOT}/02_work/12_sortmerna}"
FASTQ_SCREEN_DIR="${FASTQ_SCREEN_DIR:-${PROJECT_ROOT}/02_work/13_fastq_screen}"
TRIM14_DIR="${TRIM14_DIR:-${PROJECT_ROOT}/02_work/14_trim}"
SUB15_DIR="${SUB15_DIR:-${PROJECT_ROOT}/02_work/15_subsample}"
QC16_DIR="${QC16_DIR:-${PROJECT_ROOT}/02_work/16_qc_sub}"
ALIGN17_DIR="${ALIGN17_DIR:-${PROJECT_ROOT}/02_work/17_star}"
COUNTS18_DIR="${COUNTS18_DIR:-${PROJECT_ROOT}/02_work/18_featurecounts}"
QUALIMAP19_DIR="${QUALIMAP19_DIR:-${PROJECT_ROOT}/02_work/19_qualimap}"
MULTIQC00_DIR="${MULTIQC00_DIR:-${PROJECT_ROOT}/02_work/00_multiqc}"

SORTMERNA_HOME="${SORTMERNA_HOME:-${PROJECT_ROOT}/00_admin/env/sortmerna}"
SORTMERNA_DB_DIR="${SORTMERNA_DB_DIR:-${PROJECT_ROOT}/00_admin/env/sortmerna/db}"
SORTMERNA_THREADS="${SORTMERNA_THREADS:-8}"
FASTQ_SCREEN_HOME="${FASTQ_SCREEN_HOME:-${PROJECT_ROOT}/00_admin/env/fastq_screen}"
FASTQ_SCREEN_CONF="${FASTQ_SCREEN_CONF:-${PROJECT_ROOT}/00_admin/env/fastq_screen/fastq_screen.conf}"
FASTQ_SCREEN_THREADS="${FASTQ_SCREEN_THREADS:-8}"
BOWTIE2_MODULE="${BOWTIE2_MODULE:-bowtie2/2.5.1-u2j3omo}"
FASTP_MODULE="${FASTP_MODULE:-fastp/0.23.4}"
SEQTK_MODULE="${SEQTK_MODULE:-seqtk/1.4}"
SUBSAMPLE_READS="${SUBSAMPLE_READS:-50000000}"
